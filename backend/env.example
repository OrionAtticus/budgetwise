# Copy to .env and adjust if needed
PORT=3000
NODE_ENV=development

# PostgreSQL — matches docker-compose.yml defaults
PGHOST=localhost
PGPORT=5432
PGDATABASE=budgetwise
PGUSER=budgetwise
PGPASSWORD=budgetwise_dev

# CORS — frontend dev server origin
CORS_ORIGIN=http://localhost:5173

# Auth
SESSION_TTL_HOURS=24
BCRYPT_COST=12
PIN_MAX_ATTEMPTS=5
PIN_LOCKOUT_MINUTES=15

# Cache
DASHBOARD_CACHE_TTL_SECONDS=300
